generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  hashedPassword      String
  phone               String?
  // Per-tenant WhatsApp credentials (Phase C: BYO token).
  // Boşsa env fallback kullanılır (shared WABA modeli - Phase A).
  // waApiToken & waAppSecret AES-256-GCM ile encrypted saklanır (lib/secret-crypto.ts).
  waApiToken          String?
  waAppSecret         String?
  waVerifyToken       String?   @unique
  waWabaId            String?
  businessName        String?
  businessType        String?
  timezone            String    @default("Europe/Istanbul")
  locale              String    @default("tr")
  currency            String    @default("TRY")
  businessHoursStart  String?
  businessHoursEnd    String?
  workDays            String?
  offHoursReply       String?
  role                String    @default("OWNER")
  aiEnabled           Boolean   @default(false)
  aiProvider          String    @default("anthropic")
  aiModel             String    @default("claude-haiku-4-5")
  aiSystemPrompt      String?
  aiDailyTokenLimit   Int       @default(100000)
  plan                String    @default("STARTER")
  trialEndsAt         DateTime?
  stripeCustomerId    String?
  stripeSubscriptionId String?
  isSuperAdmin        Boolean   @default(false)
  totpSecret          String?
  totpEnabled         Boolean   @default(false)
  suspended           Boolean   @default(false)
  suspendedAt         DateTime?
  suspendReason       String?
  lastSeenAt          DateTime?
  passwordResetToken  String?   @unique
  passwordResetExpiresAt DateTime?
  emailVerifiedAt     DateTime?
  emailVerifyToken    String?   @unique
  onboardedAt         DateTime?
  onboardingStep      Int       @default(0)
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  autoReplies    AutoReply[]
  contacts       Contact[]
  messages       Message[]
  reminders      Reminder[]
  broadcasts     Broadcast[]
  templates      Template[]
  segments       Segment[]
  flows          Flow[]
  flowSessions   FlowSession[]
  aiUsages       AIUsage[]
  dailyMetrics   DailyMetric[]
  quickReplies   QuickReply[]
  teamInvites    TeamInvite[]
  apiKeys        ApiKey[]
  outgoingWebhooks OutgoingWebhook[]
  auditLogs        AdminAuditLog[]    @relation("AdminActor")
  announcements    SystemAnnouncement[] @relation("AnnouncementAuthor")
  dismissedAnnouncements AnnouncementDismissal[]
  payments         Payment[]
  supportTickets   SupportTicket[]
}

model Contact {
  id             String    @id @default(cuid())
  phone          String
  name           String
  tags           String?
  notes          String?
  optedOut       Boolean   @default(false)
  optOutAt       DateTime?
  customFields   String?
  language       String    @default("tr")
  source         String?
  lastMessageAt  DateTime?
  userId         String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  reminders Reminder[]

  @@unique([userId, phone])
  @@index([userId])
  @@index([userId, optedOut])
  @@index([userId, lastMessageAt])
}

model AutoReply {
  id           String   @id @default(cuid())
  trigger      String
  response     String
  isActive     Boolean  @default(true)
  matchType    String   @default("contains")
  assignTags   String?
  priority     Int      @default(0)
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Message {
  id           String    @id @default(cuid())
  content      String
  direction    String
  // Status değerleri: sent, delivered, read, failed, retry_pending
  // retry_pending → cron yeniden dener (exponential backoff), max 5 deneme
  status       String    @default("sent")
  phone        String
  waMessageId  String?   @unique
  deliveredAt  DateTime?
  readAt       DateTime?
  failedReason String?
  // Retry queue (Faz 4): transient failure'larda yeniden gönderim
  retryCount   Int       @default(0)
  nextRetryAt  DateTime?
  mediaType    String?
  mediaUrl     String?
  mediaId      String?
  caption      String?
  userId       String
  contactId    String?
  broadcastId  String?
  createdAt    DateTime  @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact   Contact? @relation(fields: [contactId], references: [id])

  @@unique([broadcastId, contactId])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@index([userId, direction, createdAt])
  @@index([contactId])
  @@index([broadcastId])
  // Cron için: status='retry_pending' AND nextRetryAt <= now() taraması
  @@index([status, nextRetryAt])
}

model Reminder {
  id          String   @id @default(cuid())
  message     String
  scheduledAt DateTime
  status      String   @default("pending")
  userId      String
  contactId   String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([userId, status, scheduledAt])
  @@index([contactId])
}

model Broadcast {
  id          String    @id @default(cuid())
  name        String
  message     String
  targetTags  String?
  segmentId   String?
  mediaType   String?
  mediaUrl    String?
  sentCount   Int       @default(0)
  failedCount Int       @default(0)
  rateLimit   Int       @default(80)
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  status      String    @default("draft")
  userId      String
  createdAt   DateTime  @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, scheduledAt])
}

model Template {
  id         String   @id @default(cuid())
  name       String
  language   String   @default("tr")
  category   String   @default("UTILITY")
  bodyText   String
  variables  String?
  status     String   @default("PENDING")
  metaId     String?
  rejection  String?
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, language])
  @@index([userId])
}

model Segment {
  id         String   @id @default(cuid())
  name       String
  rules      String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Flow {
  id           String        @id @default(cuid())
  name         String
  trigger      String
  triggerValue String?
  nodes        String
  isActive     Boolean       @default(true)
  userId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions     FlowSession[]

  @@index([userId])
  @@index([userId, isActive])
}

model FlowSession {
  id             String   @id @default(cuid())
  flowId         String
  contactId      String
  currentNodeId  String
  state          String
  expiresAt      DateTime
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  flow           Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contactId])
  @@index([userId])
  @@index([expiresAt])
}

model AIUsage {
  id        String   @id @default(cuid())
  userId    String
  date      String
  tokens    Int      @default(0)
  costUsd   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model DailyMetric {
  id             String   @id @default(cuid())
  userId         String
  date           String
  sent           Int      @default(0)
  delivered      Int      @default(0)
  read           Int      @default(0)
  failed         Int      @default(0)
  incomingCount  Int      @default(0)
  newContacts    Int      @default(0)
  optOuts        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model QuickReply {
  id        String   @id @default(cuid())
  shortcut  String
  content   String
  mediaUrl  String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shortcut])
  @@index([userId])
}

model TeamInvite {
  id         String    @id @default(cuid())
  userId     String
  email      String
  role       String    @default("AGENT")
  token      String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  prefix     String
  hash       String    @unique
  // Faz 9: scope-based access control. Comma-separated list:
  //   "read"  → GET endpoints (contacts list)
  //   "send"  → message send + flow trigger
  //   "write" → contact create/update
  // Legacy keys: "read,send,write" (full access, backward compat)
  scopes     String    @default("read,send,write")
  lastUsedAt DateTime?
  // Faz 9: audit trail — son kullanım IP'si ve toplam istek sayısı
  lastUsedIp String?
  usageCount Int       @default(0)
  expiresAt  DateTime?
  revokedAt  DateTime?
  userId     String
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OutgoingWebhook {
  id          String   @id @default(cuid())
  name        String
  url         String
  secret      String
  events      String
  isActive    Boolean  @default(true)
  userId      String
  // Faz 8: hızlı health snapshot — son delivery sonucu
  lastDeliveredAt   DateTime?
  lastStatusCode    Int?
  lastError         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@index([userId])
}

// Faz 8: customer'ın webhook entegrasyonunu debug edebilmesi için her
// dispatch denemesinin kaydı. dispatchWebhook fire-and-forget olduğu için
// async insert; başarısızlık ana akışı etkilemez.
model WebhookDelivery {
  id            String   @id @default(cuid())
  webhookId     String
  event         String
  // success | failed | timeout | circuit_open
  status        String
  statusCode    Int?
  responseTimeMs Int?
  errorMessage  String?
  // Payload preview — debug için ilk 2KB. Sensitive data çıkmasın diye truncate.
  payloadPreview String?
  createdAt     DateTime @default(now())

  webhook       OutgoingWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
  @@index([webhookId, status])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String?
  targetId   String?
  details    String?
  ip         String?
  createdAt  DateTime @default(now())

  actor      User     @relation("AdminActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@index([action])
  @@index([targetType, targetId])
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  status    String   @default("open")
  priority  String   @default("normal")
  closedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportTicketMessage[]

  @@index([userId, status])
  @@index([status, createdAt])
}

model SupportTicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  authorId    String
  authorRole  String
  body        String
  createdAt   DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model Payment {
  id                String    @id @default(cuid())
  userId            String
  plan              String
  amount            Int
  currency          String    @default("TRY")
  status            String    @default("pending")
  provider          String    @default("iyzico")
  providerRefId     String?
  providerToken     String?
  errorMessage      String?
  paidAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([providerRefId])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  enabled     Boolean  @default(false)
  rolloutPct  Int      @default(0)
  targetPlans String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemAnnouncement {
  id          String    @id @default(cuid())
  title       String
  content     String
  level       String    @default("info")
  audience    String    @default("all")
  isActive    Boolean   @default(true)
  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy   User                  @relation("AnnouncementAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  dismissals  AnnouncementDismissal[]

  @@index([isActive, startsAt])
}

model AnnouncementDismissal {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  dismissedAt    DateTime @default(now())

  announcement   SystemAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
}

// Meta Data Deletion Callback log.
// Meta App Review için zorunlu: kullanıcı Meta hesabından uygulamamızı
// kaldırdığında Meta bu URL'i çağırır → kayıt tutarız → confirmation_code
// + status URL döneriz. İşleme manuel admin yapar (privacy@wasend.tech).
model MetaDataDeletionRequest {
  id               String   @id @default(cuid())
  // Meta'nın signed_request payload'unda gelen FB user ID
  metaUserId       String
  // İlişkili WaSend user (varsa — yoksa orphan kayıt)
  userId           String?
  // İşleme durumu: pending / processing / completed / errored
  status           String   @default("pending")
  // Özel admin notu, tamamlanma zamanı vs.
  notes            String?
  receivedAt       DateTime @default(now())
  completedAt      DateTime?

  @@index([metaUserId])
  @@index([status])
}
