generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  hashedPassword      String
  phone               String?
  businessName        String?
  businessType        String?
  timezone            String    @default("Europe/Istanbul")
  businessHoursStart  String?
  businessHoursEnd    String?
  workDays            String?
  offHoursReply       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  autoReplies    AutoReply[]
  contacts       Contact[]
  messages       Message[]
  reminders      Reminder[]
  broadcasts     Broadcast[]
  templates      Template[]
  segments       Segment[]
}

model Contact {
  id             String    @id @default(cuid())
  phone          String
  name           String
  tags           String?
  notes          String?
  optedOut       Boolean   @default(false)
  optOutAt       DateTime?
  customFields   String?
  language       String    @default("tr")
  source         String?
  lastMessageAt  DateTime?
  userId         String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  reminders Reminder[]

  @@unique([userId, phone])
  @@index([userId])
  @@index([userId, optedOut])
  @@index([userId, lastMessageAt])
}

model AutoReply {
  id           String   @id @default(cuid())
  trigger      String
  response     String
  isActive     Boolean  @default(true)
  matchType    String   @default("contains")
  assignTags   String?
  priority     Int      @default(0)
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Message {
  id           String    @id @default(cuid())
  content      String
  direction    String
  status       String    @default("sent")
  phone        String
  waMessageId  String?   @unique
  deliveredAt  DateTime?
  readAt       DateTime?
  failedReason String?
  mediaType    String?
  mediaUrl     String?
  mediaId      String?
  caption      String?
  userId       String
  contactId    String?
  createdAt    DateTime  @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact   Contact? @relation(fields: [contactId], references: [id])

  @@index([userId, createdAt])
  @@index([contactId])
}

model Reminder {
  id          String   @id @default(cuid())
  message     String
  scheduledAt DateTime
  status      String   @default("pending")
  userId      String
  contactId   String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([userId])
  @@index([contactId])
}

model Broadcast {
  id          String    @id @default(cuid())
  name        String
  message     String
  targetTags  String?
  segmentId   String?
  mediaType   String?
  mediaUrl    String?
  sentCount   Int       @default(0)
  failedCount Int       @default(0)
  rateLimit   Int       @default(80)
  scheduledAt DateTime?
  status      String    @default("draft")
  userId      String
  createdAt   DateTime  @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, scheduledAt])
}

model Template {
  id         String   @id @default(cuid())
  name       String
  language   String   @default("tr")
  category   String   @default("UTILITY")
  bodyText   String
  variables  String?
  status     String   @default("PENDING")
  metaId     String?
  rejection  String?
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, language])
  @@index([userId])
}

model Segment {
  id         String   @id @default(cuid())
  name       String
  rules      String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
