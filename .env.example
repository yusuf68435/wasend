# --- WaSend environment ---
# Development default: SQLite file. Production: Postgres URL.
DATABASE_URL="file:./dev.db"

# NextAuth — openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Cron job auth (production). Yoksa NEXTAUTH_SECRET fallback.
CRON_SECRET=""

# WhatsApp Cloud API — https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_WABA_ID=""

# AI fallback (opsiyonel) — https://console.anthropic.com
ANTHROPIC_API_KEY=""

# Stripe (opsiyonel, STRIPE_ENABLED=true ile billing Stripe üzerinden)
STRIPE_ENABLED="false"
