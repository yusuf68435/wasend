# --- WaSend environment ---
# Development default: SQLite file. Production: Postgres URL.
DATABASE_URL="file:./dev.db"

# NextAuth — openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Cron job auth (production). Yoksa NEXTAUTH_SECRET fallback.
CRON_SECRET=""

# WhatsApp Cloud API — https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_WABA_ID=""

# SADECE DEV — imza doğrulamasını bilinçli atlamak için. Prod'da etkisiz.
# Dev'de test ederken APP_SECRET set etmek istemiyorsan: WEBHOOK_SKIP_SIGNATURE=true
WEBHOOK_SKIP_SIGNATURE=""

# AI fallback (opsiyonel) — https://console.anthropic.com
ANTHROPIC_API_KEY=""

# Email — password reset, team invite, verification.
# ÖNCELİK: RESEND_API_KEY > SMTP_HOST. Hiçbiri yoksa prod'da email gitmez.
#
# Seçenek 1: Resend (tavsiye — ücretsiz 3K/ay, https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM="WaSend <noreply@wasend.tech>"
#
# Seçenek 2: SMTP (Gmail, cPanel, custom — Resend yoksa fallback)
# Gmail: Google hesap > Security > App passwords ile 16 haneli parola oluştur.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false        # 465 kullanıyorsan true
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=abcdefghijklmnop
SMTP_HOST=""
SMTP_PORT=""
SMTP_SECURE=""
SMTP_USER=""
SMTP_PASS=""

# reCAPTCHA v3 (opsiyonel, ama bot spam için önerilir)
# https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# Google Analytics 4 (opsiyonel) — cookie consent accepted olmadan yüklenmez
NEXT_PUBLIC_GA_ID=""

# Sentry (opsiyonel) — hata izleme ve performans monitoring
# https://sentry.io → project create → DSN kopyala
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Stripe (opsiyonel, STRIPE_ENABLED=true ile billing Stripe üzerinden)
STRIPE_ENABLED="false"

# Admin bootstrap: bu e-postalarla kayıt olan kullanıcılar otomatik süper admin olur.
# Virgülle ayrılmış liste. Örn: "admin@wasend.tech,ops@wasend.tech"
ADMIN_EMAILS=""

# Admin IP whitelist — /admin sayfalarına sadece bu IP'lerden erişilebilir.
# Boş ise kontrol pasif (dev kolaylığı). Virgüllü liste. Örn: "1.2.3.4,5.6.7.8"
ADMIN_IP_ALLOWLIST=""
